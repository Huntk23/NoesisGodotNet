<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FF1B2430">

  <!-- Everything here uses the official Noesis theme's implicit styles.
       No local templates — if anything renders pink, the theme didn't load. -->

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
    <StackPanel MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center">
      <TextBlock Text="THEME LAB" FontSize="32" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="Official Noesis theme, zero local templates. Scroll me with the mouse wheel."
                 TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,24"/>

      <TextBlock Text="Player name" Margin="0,0,0,4"/>
      <TextBox Text="{Binding PlayerName, UpdateSourceTrigger=PropertyChanged}"/>
      <TextBlock Text="{Binding Greeting}" Margin="0,6,0,18" Opacity="0.85"/>

      <CheckBox Content="Enable awesome mode" IsChecked="{Binding AwesomeMode}"/>
      <TextBlock Text="{Binding AwesomeStatus}" Margin="0,4,0,18" Opacity="0.85"/>

      <TextBlock Text="{Binding VolumeLabel}" Margin="0,0,0,4"/>
      <Slider Value="{Binding Volume}" Minimum="0" Maximum="100" SmallChange="1" LargeChange="10"/>

      <TextBlock Text="Quality" Margin="0,18,0,4"/>
      <ComboBox ItemsSource="{Binding QualityOptions}" SelectedItem="{Binding Quality}"/>

      <ProgressBar Value="{Binding Volume}" Maximum="100" Height="10" Margin="0,18,0,0"/>

      <Button Content="Reset" Command="{Binding ResetCommand}"
              HorizontalAlignment="Center" Margin="0,24,0,0" Padding="24,8"/>

      <!-- filler so the ScrollViewer has something to scroll at small sizes -->
      <TextBlock Text="…" HorizontalAlignment="Center" Opacity="0.4" Margin="0,32,0,0"/>
      <TextBlock Text="You scrolled. The wheel path works."
                 HorizontalAlignment="Center" Opacity="0.6" Margin="0,120,0,32"/>
    </StackPanel>
  </ScrollViewer>
</Grid>
