<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid.Background>
    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
      <GradientStop Offset="0" Color="#FF123F5A"/>
      <GradientStop Offset="1" Color="#FF001B2E"/>
    </LinearGradientBrush>
  </Grid.Background>

  <!-- Explicit button style so the sample works without the Noesis theme package -->
  <Grid.Resources>
    <Style x:Key="MenuButton" TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="Margin" Value="0,6"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bg" Background="#33FFFFFF" CornerRadius="6"
                    BorderBrush="#66FFFFFF" BorderThickness="1" Padding="32,10">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bg" Property="Background" Value="#5548A9D8"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bg" Property="Background" Value="#7748A9D8"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Grid.Resources>

  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
    <TextBlock Text="{Binding Title}" FontSize="52" FontWeight="Bold"
               Foreground="White" HorizontalAlignment="Center"/>
    <TextBlock Text="NoesisGUI running inside Godot" FontSize="16"
               Foreground="#AAFFFFFF" HorizontalAlignment="Center" Margin="0,4,0,32"/>

    <Button Content="New Game" Style="{StaticResource MenuButton}"
            Command="{Binding NewGameCommand}"/>
    <Button Content="Options" Style="{StaticResource MenuButton}"
            Command="{Binding OptionsCommand}"/>
    <Button Content="Quit" Style="{StaticResource MenuButton}"
            Command="{Binding QuitCommand}"/>

    <TextBlock Text="{Binding Status}" FontSize="14" Foreground="#FF7FD4FF"
               HorizontalAlignment="Center" Margin="0,28,0,0"/>
  </StackPanel>
</Grid>
