; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="NoesisGodotNet"
run/main_scene="res://examples/HelloNoesis/Main.tscn"
config/features=PackedStringArray("4.7", "C#")

[dotnet]

project/assembly_name="NoesisGodot"

[editor_plugins]

enabled=PackedStringArray("res://addons/noesisgui/plugin.cfg")

[noesis_gui]

license/name=""
license/key=""
resources/root="res://examples/HelloNoesis/UI"
resources/fonts="res://examples/HelloNoesis/UI/Fonts"
